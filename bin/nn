#!/usr/bin/env bash
# nn — notenav entry point
# TUI faceted browser for zk notebooks

_realpath() {
  if readlink -f "$1" 2>/dev/null; then return; fi
  local path="$1"
  while [ -L "$path" ]; do
    local dir; dir="$(cd "$(dirname "$path")" && pwd)"
    path="$(readlink "$path")"
    [[ "$path" != /* ]] && path="$dir/$path"
  done
  echo "$(cd "$(dirname "$path")" && pwd)/$(basename "$path")"
}

NOTENAV_ROOT="$(dirname "$(dirname "$(_realpath "$0")")")"
source "$NOTENAV_ROOT/lib/notenav.sh"
notenav_main "$@"
